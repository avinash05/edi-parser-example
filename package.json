{
  "name": "@edi-parser/examples",
  "version": "1.0.0",
  "description": "Example applications demonstrating the EDI Parser library for X12 HIPAA 5010 271 transactions",
  "private": true,
  "scripts": {
    "build": "tsc",
    "csv-extractor": "npx ts-node src/csv-extractor-example.ts",
    "dws-client": "npx ts-node src/dws-client-example.ts",
    "edi-parser": "npx ts-node src/edi-parser-example.ts",
    "edi-normalizer": "npx ts-node src/edi-normalizer-example.ts",
    "eligibility-processor": "npx ts-node src/eligibility-processor-example.ts",
    "find-decoded": "npx ts-node src/find-decoded-data.ts",
    "simplified": "npx ts-node src/simplified-demo.ts",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@edi-parser/core": "file:../edi-parser",
    "csv-parser": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
